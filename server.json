{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.takiguchi-yu/google-workspace-mcp",
  "description": "An MCP server for Google Workspaces.",
  "repository": {
    "url": "https://github.com/takiguchi-yu/google-workspace-mcp",
    "source": "github"
  },
  "version": "0.0.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@takiguchi-yu/google-workspace-mcp-server",
      "version": "0.0.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Your API key for the service",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "YOUR_API_KEY"
        }
      ]
    }
  ]
}
