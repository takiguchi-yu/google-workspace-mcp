{
  "name": "@takiguchi-yu/google-workspace-mcp-server",
  "version": "0.0.10",
  "mcpName": "io.github.takiguchi-yu/google-workspace-mcp-server",
  "workspaces": [],
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/takiguchi-yu/google-workspace-mcp-server.git"
  },
  "description": "An MCP server for Google Workspaces.",
  "type": "module",
  "scripts": {
    "clean-install": "rm -rf node_modules && npm install",
    "setup": "node ./dist/scripts/oauth-server.js",
    "setup:dev": "node ./src/scripts/oauth-server.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "tsc",
    "sync-version": "node ./scripts/sync-version.js",
    "version": "npm run sync-version && git add server.json",
    "start": "node ./dist/index.js"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run type-check && npm run lint && npm run format:check"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  },
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0"
  }
}
